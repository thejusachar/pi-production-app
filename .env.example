# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit the real .env file to Git!

# Your Docker Hub username (e.g. thejesh)
DOCKER_HUB_USERNAME=your-dockerhub-username

# The image version to deploy on the Pi
# Set to a specific version tag like "1.2.0", or "latest"
IMAGE_TAG=latest
